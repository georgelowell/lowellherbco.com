---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="store-locator-page" style="padding: 180px 15px 60px; max-width: 1200px; margin: 0 auto;">
    <h2 class="common-h2" style="text-align: center; margin-bottom: 40px;">Store Locator</h2>
    <div style="height: 50px;">&nbsp;</div>

    <!-- Store locator placeholder — your bespoke implementation goes here -->
    <div id="lowell-store-locator" style="min-height: 400px; border: 1px dashed #ccc; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px;">
      <div>
        <p style="font: normal normal 400 18px/1.6 var(--font-sans); color: var(--text-gray);">
          Store locator coming soon
        </p>
        <p style="font: normal normal 400 14px/1.6 var(--font-sans); color: var(--text-muted); margin-top: 10px;">
          Your custom-built store locator will render here
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
