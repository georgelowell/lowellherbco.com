<style>
  .hero {
    position: relative;
    padding: 180px 0 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    height: 100vh;
    min-height: 600px;
  }

  .hero-background-video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    left: 0;
    top: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }

  .heading-text {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 20px;
  }

  .hero h1 {
    color: var(--white);
  }

  .hero .text-img {
    max-width: 592px;
    margin: 0 auto;
    display: block;
  }

  .hero .hero-sub {
    color: var(--white);
    font: normal normal 400 16px/1.6 var(--font-sans);
    text-align: center;
    max-width: 800px;
    margin: 22px auto;
  }

  .hero-footer {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-align: center;
  }

  .hero-footer p {
    color: var(--white);
    font: normal normal 400 16px/1.6 var(--font-serif);
    margin-bottom: 10px;
  }

  .hero-footer .social-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .hero-footer .social-links a {
    color: var(--white);
    font-size: 20px;
    transition: opacity 0.3s;
  }

  .hero-footer .social-links a:hover {
    opacity: 0.7;
  }

  .scroll-prompt {
    position: absolute;
    z-index: 3;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .scroll-prompt-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid #bebebe;
    border-bottom: 2px solid #bebebe;
    transform: rotate(45deg);
    animation: bounce 1.5s infinite;
  }

  .scroll-prompt-arrow:nth-child(2) {
    margin-top: -8px;
    animation-direction: reverse;
  }

  @keyframes bounce {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }
</style>

<section class="hero">
  <video class="hero-background-video" autoplay muted loop playsinline poster="/images/hero-text.png">
    <source src="/video/video-1.mp4" type="video/mp4">
  </video>
  <div class="hero-overlay"></div>

  <div class="heading-text">
    <h1 class="main-heading">Great American Cannabis</h1>
    <p class="hero-sub">Born at the dawn of legalization, Lowell has become America's favorite preroll with a footprint that spans across the United States of America. The reason for our success is simple:</p>
    <img src="/images/hero-text.png" alt="Nothing Smokes Like a Lowell" class="text-img">
  </div>

  <div class="scroll-prompt">
    <div class="scroll-prompt-arrow"></div>
    <div class="scroll-prompt-arrow"></div>
  </div>

  <div class="hero-footer">
    <p>Follow us</p>
