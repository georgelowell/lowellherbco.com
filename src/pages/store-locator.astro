---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="store-locator-page" style="padding: 120px 15px 60px; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 30px;">
      <h2 class="common-h2" style="margin-bottom: 12px;">Find Lowell Near You</h2>
      <p style="color: var(--text-gray); font: normal normal 400 16px/1.6 var(--font-sans); max-width: 600px; margin: 0 auto;">
        Pick a product and find stores near you that carry it. Select your state below.
      </p>
    </div>

    <!-- State selector -->
    <div style="text-align: center; margin-bottom: 20px;">
      <label for="state-select" style="font: normal normal 400 14px/1.6 var(--font-sans); color: var(--text-gray); margin-right: 10px;">State:</label>
      <select id="state-select" style="padding: 8px 16px; font: normal normal 400 15px/1.5 var(--font-sans); border: 1px solid #ccc; border-radius: 6px; background: white;">
        <option value="NY">New York</option>
        <option value="NJ">New Jersey</option>
        <option value="IL">Illinois</option>
        <option value="CO">Colorado</option>
        <option value="CA">California</option>
      </select>
    </div>

    <!-- Embedded store finder -->
    <div id="store-finder-embed" style="width: 100%; min-height: 600px; border: none; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08);">
      <iframe
        id="store-finder-iframe"
        src="https://lowell-find.netlify.app"
        title="Lowell Store Finder"
        style="width: 100%; height: 700px; border: none;"
        allow="geolocation"
        loading="lazy"
      ></iframe>
    </div>

    <p style="text-align: center; color: var(--text-muted); font: normal normal 400 13px/1.6 var(--font-sans); margin-top: 16px;">
      Find stores near you that carry Lowell products. Select a product and enter your zip code to see nearby retailers with current inventory.
    </p>
  </section>
</BaseLayout>

<script>
  (function() {
    const select = document.getElementById('state-select');
    const iframe = document.getElementById('store-finder-iframe');

    select.addEventListener('change', function() {
      // The store finder iframe currently loads from lowell-find.netlify.app.
      // Once the expanded backend is deployed, we can pass ?state=NJ etc.
      // For now this is a future capability.
      console.log('State changed to:', this.value);
    });
  })();
</script>

<style is:global>
  #store-finder-embed iframe {
    max-width: 500px;
    margin: 0 auto;
    display: block;
  }

  @media (min-width: 768px) {
    #store-finder-embed iframe {
      max-width: 500px;
    }
  }
</style>
