---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="store-locator-page" style="padding: 180px 15px 60px; max-width: 1200px; margin: 0 auto;">
    <h2 class="common-h2" style="text-align: center; margin-bottom: 16px;">Find Lowell Near You</h2>
    <p style="text-align: center; color: var(--text-gray); font: normal normal 400 16px/1.6 var(--font-sans); max-width: 600px; margin: 0 auto 40px;">
      Find a retailer near you carrying Lowell Herb Co. products.
    </p>

    <!-- Stockist.co Store Locator Widget -->
    <div id="lowell-store-locator" style="min-height: 500px;">
      <stockist-store-locator data-stockist-widget-tag="u24108"></stockist-store-locator>
    </div>
  </section>
</BaseLayout>

<script>
  // Load the Stockist.co widget script
  (function() {
    const script = document.createElement('script');
    script.src = 'https://cdn.stockist.co/embed/embed.min.js';
    script.async = true;
    document.head.appendChild(script);
  })();
</script>
