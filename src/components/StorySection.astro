---
export interface Props {
  image: string;
  imageAlt?: string;
  heading: string;
  text: string;
  imagePosition?: 'left' | 'right';
}

const { image, imageAlt = '', heading, text, imagePosition = 'left' } = Astro.props;
const positionClass = imagePosition === 'right' ? 'ic-right-img' : 'ic-left-img';
---

<style>
  .image-content-box {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    padding: 60px 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  .image-content-box.ic-left-img {
    flex-direction: row;
  }

  .image-content-box.ic-right-img {
    flex-direction: row-reverse;
  }

  .ic-image {
    width: calc(50% - 50px);
    min-height: 500px;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  .ic-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ic-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    gap: 20px;
    padding: 40px;
  }

  .ic-content .herb-icon {
    margin-bottom: 0;
    max-width: 98px;
    height: 26px;
  }

  .ic-content h2 {
    color: var(--text-dark);
    max-width: 400px;
    margin: 0 auto;
  }

  .ic-content p {
    color: var(--text-charcoal);
    font: normal normal 400 16px/1.6 var(--font-sans);
    max-width: 460px;
  }

  @media (max-width: 767px) {
    .image-content-box {
      flex-direction: column !important;
      min-height: auto;
      padding: 30px 15px;
    }

    .ic-image {
      position: static !important;
      width: 100% !important;
      min-height: 300px;
      flex-shrink: 1;
    }

    .ic-content {
      width: 100%;
      padding: 30px 15px;
    }
  }
</style>

<section class={`image-content-box ${positionClass}`}>
  <figure class="ic-image">
    <img src={image} alt={imageAlt} loading="lazy" />
  </figure>
  <div class="ic-content">
    <img src="/images/herb-icon.svg" alt="" class="herb-icon" aria-hidden="true" />
    <h2 class="common-h2">{heading}</h2>
    <p>{text}</p>
  </div>
</section>
