---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="follow-page" style="padding: 180px 15px 60px; max-width: 800px; margin: 0 auto;">
    <h2 class="common-h2" style="text-align: center; margin-bottom: 16px;">Follow Us</h2>
    <p style="text-align: center; color: var(--text-gray); font: normal normal 400 16px/1.6 var(--font-sans); margin-bottom: 40px;">
      Stay connected with Lowell. Sign up for updates, new product drops, and more.
    </p>

    <!-- Mailchimp signup form -->
    <div id="mc_embed_shell" style="max-width: 600px; margin: 0 auto;">
      <div id="mc_embed_signup">
        <form action="https://lowellherbco.us1.list-manage.com/subscribe/post?u=YOUR_MAILCHIMP_U&amp;id=YOUR_MAILCHIMP_ID&amp;f_id=YOUR_F_ID" method="post" id="mc-embedded-subscribe-form" name="mc-embedded-subscribe-form" class="validate" target="_blank">
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <div>
              <label for="mce-EMAIL" style="font: normal normal 400 14px/1.6 var(--font-sans); color: var(--text-gray); display: block; margin-bottom: 4px;">
                Email Address <span style="color: red;">*</span>
              </label>
              <input type="email" name="EMAIL" id="mce-EMAIL" required
                placeholder="your@email.com"
                style="width: 100%; padding: 14px 16px; border: 1px solid #ccc; font: normal normal 400 16px/1.6 var(--font-sans); background: var(--white);">
            </div>
            <div>
              <label for="mce-FNAME" style="font: normal normal 400 14px/1.6 var(--font-sans); color: var(--text-gray); display: block; margin-bottom: 4px;">
                First Name
              </label>
              <input type="text" name="FNAME" id="mce-FNAME"
                placeholder="Your first name"
                style="width: 100%; padding: 14px 16px; border: 1px solid #ccc; font: normal normal 400 16px/1.6 var(--font-sans); background: var(--white);">
            </div>
            <div hidden>
              <input type="text" name="b_YOUR_MAILCHIMP_U_YOUR_MAILCHIMP_ID" tabindex="-1" value="">
            </div>
            <div style="text-align: center; margin-top: 8px;">
              <input type="submit" name="subscribe" id="mc-embedded-subscribe" value="Subscribe"
                class="btn-clr"
                style="border: none; cursor: pointer;">
            </div>
          </div>
        </form>
      </div>
    </div>

    <div style="text-align: center; margin-top: 60px;">
      <p style="font: normal normal 400 16px/1.6 var(--font-sans); color: var(--text-gray); margin-bottom: 16px;">Follow us on social</p>
      <div style="display: flex; justify-content: center; gap: 16px;">
        <a href="https://www.instagram.com/lowellherbco" target="_blank" style="width: 48px; height: 48px; background: var(--button-burgundy); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: var(--white);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.instagram.com/lowellfarms" target="_blank" style="width: 48px; height: 48px; background: var(--button-burgundy); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: var(--white);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://twitter.com/lowellfarms" target="_blank" style="width: 48px; height: 48px; background: var(--button-burgundy); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: var(--white);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
